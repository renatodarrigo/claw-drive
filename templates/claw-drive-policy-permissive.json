{
  "_comment": "Permissive dogfood policy variant — adds wider auto_approve rules for compound scripts (set -e, cd, VAR=, source, etc. wrapping a safe payload) so multi-step driver workflows don't hit excessive escalation gates. Same auto_reject and auto_defer guardrails as the starter template. Underscore-prefixed keys (this _comment, _version, etc.) are ignored by the validator and safe to add for inline metadata.",
  "auto_approve": [
    { "tool": "Read" },
    { "tool": "Glob" },
    { "tool": "Grep" },
    { "tool": "Bash", "bash_command_matches": "^git (status|diff|log|show|branch|stash list|ls-files|rev-parse|worktree list) ?" },
    { "tool": "Bash", "bash_command_matches": "^(ls|cat|head|tail|find|file|tree|wc|pwd|echo|stat|wc|du|df) " },
    { "tool": "Bash", "bash_command_matches": "^(npm|npx|node) " },
    { "tool": "Bash", "bash_command_matches": "^cloverleaf-cli " },
    { "tool": "Bash", "bash_command_matches": "cloverleaf-cli ", "name": "cloverleaf-cli anywhere in compound script (set -e, cd, REPO=, etc.)" },
    { "tool": "Bash", "bash_command_matches": "^(set -e|cd |REPO=|export\\s|source )", "name": "common shell prefixes that usually wrap a safe payload" },
    { "tool": "Bash", "bash_command_matches": "^(rg|sed -n|awk|jq|diff|cmp|column)\\s", "name": "common read/inspect CLIs" },
    { "tool": "Bash", "bash_command_matches": "^(mkdir -p|touch|cp(?!\\s+(-[^-\\s]*[rRa]|--recursive|--archive))|mv)(\\s|$)", "name": "common non-destructive file ops — cp recursive forms (-r, -R, -a, -pR, --recursive, --archive) still escalate" },
    { "tool": "Bash", "bash_command_matches": "^git (fetch|pull --ff-only|rebase --abort|rebase --continue|rebase --skip|cherry-pick --abort|merge --abort)(\\s|$)", "name": "common safe git ops" },
    { "tool": "Bash", "bash_command_matches": "^(which|type|printenv|basename|dirname|realpath|readlink)(\\s|$)", "name": "common path/env introspection (env intentionally excluded — it execs its argv)" },
    { "tool": "Bash", "bash_command_matches": "^#", "name": "comment-prefixed line — destructive lines anywhere in the script still caught by auto_reject" }
  ],

  "auto_defer": [
    { "tool": "Bash", "bash_command_matches": "^sudo\\s", "name": "sudo requires human password" },
    { "tool": "Bash", "bash_command_matches": "^su\\s", "name": "su requires human password" },
    { "tool": "Bash", "bash_command_matches": "^echo 'CLAW-GATE:", "name": "review-gate convention (B asks for human OK)", "severity": "medium" },
    { "tool": "Bash", "bash_command_matches": "^echo \"CLAW-GATE:", "name": "review-gate convention (B asks for human OK)", "severity": "medium" },
    { "tool": "Bash", "bash_command_matches": "\\bchmod\\s+-R\\s+777\\b", "name": "chmod -R 777 — recoverable but almost always wrong", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bchown\\s+-R\\b", "name": "chown -R — recursive ownership change", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\btruncate\\b", "name": "truncate — zero-out or resize (common log-rotation idiom, but destructive on DBs)", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bkill\\s+-9\\b.*?\\s(-1|0|1)(\\s|$|[;&|])", "name": "kill -9 of init/everything/process-group (PID 1, -1, or 0)", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bsystemctl\\s+(--?[\\w-]+(=\\S+)?\\s+)*(stop|disable|kill|mask)\\b", "name": "systemctl stop/disable/kill/mask — service teardown", "severity": "high" }
  ],

  "auto_reject": [
    {
      "tool": "Bash",
      "bash_command_matches": "\\brm\\s+(-[a-zA-Z]*[rR]|--recursive)|\\brm --no-preserve-root\\b|\\bgit push\\b|\\bgit reset --hard\\b|\\bgit clean -fdx\\b|\\bnpm publish\\b|\\bdd if=|\\bmkfs\\b|\\bshred\\b|\\b(fdisk|parted|gdisk|sgdisk)\\b|\\b(curl|wget)\\s.*\\|\\s*(sudo\\s+)?(bash|sh|zsh)\\b|> /dev/(sd[a-z]|nvme\\d+n\\d+|xvd[a-z]|hd[a-z]|loop\\d*|mmcblk\\d+|vd[a-z])",
      "severity": "high",
      "name": "irreversible / destructive"
    }
  ],

  "escalate_default": true,
  "decision_timeout_seconds": 3600
}
