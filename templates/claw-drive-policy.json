{
  "_comment": "Starting-point dogfood policy shipped with claw-drive. Tighten or loosen as you learn what a driven session actually does. Rules are evaluated in order: auto_reject > auto_defer > auto_approve > escalate_default. Underscore-prefixed keys (this _comment, _version, etc.) are ignored by the validator and safe to add for inline metadata.",
  "auto_approve": [
    { "tool": "Read" },
    { "tool": "Glob" },
    { "tool": "Grep" },
    { "tool": "Bash", "bash_command_matches": "^git( -C \\S+)? (status|diff|log|show|branch|stash list|ls-files|rev-parse|worktree list)(\\s|$)" },
    { "tool": "Bash", "bash_command_matches": "^(ls|cat|head|tail|find|file|tree|wc|pwd|echo|stat|wc|du|df) " },
    { "tool": "Bash", "bash_command_matches": "^(npm|npx) " },
    { "tool": "Bash", "bash_command_matches": "^node\\s+(?!(--eval|--print|-[a-zA-Z]*[ep])\\b)", "name": "node <script> — eval/print forms (-e/--eval/-p/--print) are excluded and hit auto_defer" },
    { "tool": "Bash", "bash_command_matches": "^cloverleaf-cli " },
    { "tool": "Bash", "bash_command_matches": "cloverleaf-cli ", "name": "cloverleaf-cli anywhere in compound script (set -e, cd, REPO=, etc.)" },
    { "tool": "Bash", "bash_command_matches": "^(set -e|cd |REPO=|export\\s|source )", "name": "common shell prefixes that usually wrap a safe payload" }
  ],

  "auto_defer": [
    { "tool": "Bash", "bash_command_matches": "^sudo\\s", "name": "sudo requires human password" },
    { "tool": "Bash", "bash_command_matches": "^su\\s", "name": "su requires human password" },
    { "tool": "Bash", "bash_command_matches": "^echo 'CLAW-GATE:", "name": "review-gate convention (B asks for human OK)", "severity": "medium" },
    { "tool": "Bash", "bash_command_matches": "^echo \"CLAW-GATE:", "name": "review-gate convention (B asks for human OK)", "severity": "medium" },
    { "tool": "Bash", "bash_command_matches": "\\bchmod\\s+-R\\s+777\\b", "name": "chmod -R 777 — recoverable but almost always wrong", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bchown\\s+-R\\b", "name": "chown -R — recursive ownership change", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\btruncate\\b", "name": "truncate — zero-out or resize (common log-rotation idiom, but destructive on DBs)", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bkill\\s+-9\\b.*?\\s(-1|0|1)(\\s|$|[;&|])", "name": "kill -9 of init/everything/process-group (PID 1, -1, or 0)", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bsystemctl\\s+(--?[\\w-]+(=\\S+)?\\s+)*(stop|disable|kill|mask)\\b", "name": "systemctl stop/disable/kill/mask — service teardown", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bpython[0-9.]*\\s+-c\\b", "name": "python -c — runs arbitrary code the command regex can't inspect", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bnode\\s+(--eval|--print|-[a-zA-Z]*[ep])\\b", "name": "node -e/--eval/-p/--print — runs arbitrary code", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bperl[0-9.]*\\s+-e\\b", "name": "perl -e — runs arbitrary code", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bruby[0-9.]*\\s+-e\\b", "name": "ruby -e — runs arbitrary code", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\bphp[0-9.]*\\s+-r\\b", "name": "php -r — runs arbitrary code", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "(?:^|[;&|]\\s*)eval(?:\\s|$)", "name": "eval — shell evaluates a constructed string", "severity": "high" },
    { "tool": "Bash", "bash_command_matches": "\\b(sh|bash|zsh)\\s+(-\\S+\\s+)*-[a-z]*c\\b", "name": "sh/bash/zsh -c — inline shell string bypasses command-level inspection", "severity": "high" }
  ],

  "auto_reject": [
    {
      "tool": "Bash",
      "bash_command_matches": "\\brm\\s+(-[a-zA-Z]*[rR]|--recursive)|\\brm --no-preserve-root\\b|\\bgit push\\b|\\bgit reset --hard\\b|\\bgit clean -fdx\\b|\\bnpm publish\\b|\\bdd if=|\\bmkfs\\b|\\bshred\\b|\\b(fdisk|parted|gdisk|sgdisk)\\b|\\b(curl|wget)\\s.*\\|\\s*(sudo\\s+)?(bash|sh|zsh)\\b|> /dev/(sd[a-z]|nvme\\d+n\\d+|xvd[a-z]|hd[a-z]|loop\\d*|mmcblk\\d+|vd[a-z])",
      "severity": "high",
      "name": "irreversible / destructive"
    },
    { "tool": "Edit",  "arg_matches": { "file_path": "claw-drive-policy[^/]*\\.json$" }, "severity": "high", "name": "policy file (Edit) — claw-drive's own privilege boundary" },
    { "tool": "Write", "arg_matches": { "file_path": "claw-drive-policy[^/]*\\.json$" }, "severity": "high", "name": "policy file (Write) — claw-drive's own privilege boundary" },
    { "tool": "Edit",  "arg_matches": { "file_path": "(?:^|/)\\.claw-drive/" }, "severity": "high", "name": "claw-drive runtime state (Edit) — sessions, sockets, events" },
    { "tool": "Write", "arg_matches": { "file_path": "(?:^|/)\\.claw-drive/" }, "severity": "high", "name": "claw-drive runtime state (Write) — sessions, sockets, events" },
    {
      "tool": "Bash",
      "bash_command_matches": "(((\\bcp|\\bmv|\\brsync|\\btee)\\s+|sed\\s+-i\\s+|awk\\s+-i\\s+inplace\\s+|dd\\s+of=)[^|;&]*?(claw-drive-policy[^\\s/]*\\.json|(?:^|/)\\.claw-drive/)|>{1,2}\\s*[^|;&]*(claw-drive-policy[^\\s/]*\\.json|(?:^|/)\\.claw-drive/))",
      "severity": "high",
      "name": "bash writes to policy file or claw-drive runtime state"
    }
  ],

  "escalate_default": true,
  "decision_timeout_seconds": 3600,

  "_budget_example": {
    "_comment": "Run-level circuit-breaker (CD-4). RENAME this key to \"budget\" to enable it — it is OFF by default. All fields optional; an absent field is unlimited. On breach the runner reaps the session (SIGTERM then SIGKILL) with exit_reason budget_exceeded:<cap>.",
    "max_tool_calls": 500,
    "max_wall_clock_seconds": 3600,
    "max_consecutive_errors": 5
  }
}
